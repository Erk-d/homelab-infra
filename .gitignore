# ## System & IDE Files ##
# Ignore macOS system files
.DS_Store

# Ignore Visual Studio Code settings directory
.vscode/

# Ignore Python cache files
__pycache__/


# ## Ansible Files ##
# Ignore temporary files created by Ansible runs
*.retry

# Ignore Ansible Vault password files
vault.pass
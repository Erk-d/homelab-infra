# Wyze account credentials
WYZE_EMAIL=your@email.com
WYZE_PASSWORD=yourpassword

# Wyze API credentials — get from https://developer-api-console.wyze.com
WYZE_API_ID=your-api-id
WYZE_API_KEY=your-api-key

# Camera filter — exact name as it appears in the Wyze app (comma-separated for multiple)
# Leave empty to stream all cameras
WYZE_FILTER_NAMES=Chicken Run
